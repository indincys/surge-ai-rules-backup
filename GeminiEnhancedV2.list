# NAME: GeminiEnhancedV2
# DESCRIPTION: Widened Gemini-focused ruleset for keeping Gemini and its Google
#              login/support surfaces on the same outbound identity.
# PLACEMENT: Put YouTube rulesets ABOVE this file. Put this file ABOVE generic
#            Google and generic AI rulesets.
# GOAL: Be wider than a pure Gemini ruleset, but still avoid unrelated AI
#       vendors that are already maintained in separate rulesets.
# NOTE: Because this file intentionally includes broad Google support domains
#       like googleapis.com and googleusercontent.com, YouTube-specific rules
#       must come earlier to keep playback/download traffic out of AI/home nodes.
# SOURCES: blackmatrix7 Gemini, MetaCubeX google-gemini, bojin google-gemini,
#          norules Gemini, janlay loc-sens.

# Core Gemini / Google AI surfaces
DOMAIN,ai.google.dev
DOMAIN,accounts.google.com
DOMAIN,ogs.google.com
DOMAIN,aida.googleapis.com
DOMAIN,aisandbox-pa.googleapis.com
DOMAIN,alkalicore-pa.clients6.google.com
DOMAIN,alkalimakersuite-pa.clients6.google.com
DOMAIN,antigravity-pa.googleapis.com
DOMAIN,antigravity.googleapis.com
DOMAIN,cloudaicompanion.googleapis.com
DOMAIN,cloudcode-pa.googleapis.com
DOMAIN,daily-cloudcode-pa.googleapis.com
DOMAIN,jules.google.com
DOMAIN,makersuite.google.com
DOMAIN,notebooklm-pa.googleapis.com
DOMAIN,notebooklm.googleapis.com
DOMAIN,phonedeviceverification-pa.googleapis.com
DOMAIN,webchannel-alkalimakersuite-pa.clients6.google.com

# Product and site surfaces
DOMAIN-SUFFIX,aistudio.google.com
DOMAIN-SUFFIX,antigravity-unleash.goog
DOMAIN-SUFFIX,antigravity.google
DOMAIN-SUFFIX,apis.google.com
DOMAIN-SUFFIX,bard.google.com
DOMAIN-SUFFIX,deepmind.com
DOMAIN-SUFFIX,deepmind.google
DOMAIN-SUFFIX,geller-pa.googleapis.com
DOMAIN-SUFFIX,gemini.google
DOMAIN-SUFFIX,gemini.google.com
DOMAIN-SUFFIX,generativeai.google
DOMAIN-SUFFIX,generativelanguage.googleapis.com
DOMAIN-SUFFIX,jules.google
DOMAIN-SUFFIX,labs.google
DOMAIN-SUFFIX,labs.google.com
DOMAIN-SUFFIX,makersuite.google.com
DOMAIN-SUFFIX,notebooklm.google
DOMAIN-SUFFIX,notebooklm.google.com
DOMAIN-SUFFIX,opal.google
DOMAIN-SUFFIX,opal.google.com
DOMAIN-SUFFIX,proactivebackend-pa.googleapis.com
DOMAIN-SUFFIX,robinfrontend-pa.googleapis.com

# Requested broader Google support domains
DOMAIN-SUFFIX,google.com
DOMAIN-SUFFIX,googleapis.com
DOMAIN-SUFFIX,gstatic.com
DOMAIN-SUFFIX,googleusercontent.com
DOMAIN-SUFFIX,googletagmanager.com

# Gemini-related keyword matches retained from upstream Gemini lists
DOMAIN-KEYWORD,alkalimakersuite-pa.clients6.google.com
DOMAIN-KEYWORD,colab
DOMAIN-KEYWORD,developerprofiles
DOMAIN-KEYWORD,generativelanguage

# Keep the Google login handoff narrow instead of routing all www.google.com
URL-REGEX,https://www\.google\.com/.*continue=https://gemini\.google\.com.+
